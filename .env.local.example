# trace-app local dev environment variables
# Copy this file to .env.local and fill in the values

# Production Vercel API base URL
EXPO_PUBLIC_API_BASE_URL=https://trace-beta-seven.vercel.app

# Ed25519 signing public key (SPKI base64 format, 44 chars)
# Value: NEXT_PUBLIC_SIGNING_PUBKEY from the trace Vercel project's environment variables
# Used to verify the server's X25519 key during key exchange (strip 12-byte SPKI header → raw 32 bytes)
EXPO_PUBLIC_SIGNING_PUBKEY=
